# Deployer wallet private key (for contract deployment)
PRIVATE_KEY=your_private_key_here

# Alchemy RPC URL (used by both Hardhat and the frontend).
# Optional — defaults to the public https://rpc.testnet.arc.network. That public
# endpoint rate-limits (HTTP 429) under the app's polling; use a dedicated
# provider (Alchemy/etc.) for demos or heavy use.
NEXT_PUBLIC_RPC_URL=https://your-alchemy-rpc-url-here

# ArcScan API key (for contract verification, optional)
ARCSCAN_API_KEY=your_arcscan_api_key_here

# Circle modular wallets (required for passkey wallet support)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=your_circle_client_key_here
NEXT_PUBLIC_CIRCLE_CLIENT_URL=your_circle_client_url_here

# Contract addresses
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_LENDING_ADDRESS=
NEXT_PUBLIC_CIRBTC_ADDRESS=

# Block explorer URL (used for transaction hash links; optional)
NEXT_PUBLIC_EXPLORER_URL=

# Local Supabase (populated by `npm run db:start` — copy the printed values)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=